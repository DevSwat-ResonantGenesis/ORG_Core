name: Backend Integration Tests

on:
  pull_request:
    paths:
      - 'gateway/**'
      - 'auth_service/**'
      - 'blockchain_service/**'
      - '.github/workflows/backend-tests.yml'
  push:
    branches:
      - main
      - develop
    paths:
      - 'gateway/**'
      - 'auth_service/**'
      - 'blockchain_service/**'
  workflow_dispatch:

concurrency:
  group: backend-tests-${{ github.ref }}
  cancel-in-progress: true

env:
  PYTHON_VERSION: "3.11"
  TESTING: "true"

jobs:
  gateway-tests:
    name: Gateway API Tests
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'
          cache-dependency-path: gateway/requirements.txt

      - name: Install dependencies
        working-directory: gateway
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install pytest pytest-asyncio httpx pytest-cov

      - name: Run Gateway Tests
        working-directory: gateway
        env:
          PYTHONPATH: ${{ github.workspace }}/gateway:${{ github.workspace }}
          TESTING: "true"
        run: |
          pytest tests/ -v --tb=short --junitxml=test-results.xml

      - name: Upload Test Results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: gateway-test-results
          path: gateway/test-results.xml

  auth-tests:
    name: Auth Service Tests
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'
          cache-dependency-path: auth_service/requirements.txt

      - name: Install dependencies
        working-directory: auth_service
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install pytest pytest-asyncio httpx pytest-cov

      - name: Run Auth Tests
        working-directory: auth_service
        env:
          PYTHONPATH: ${{ github.workspace }}/auth_service:${{ github.workspace }}
          TESTING: "true"
          JWT_SECRET_KEY: "test-jwt-secret-for-ci"
          DATABASE_URL: "sqlite:///./test.db"
        run: |
          pytest tests/ -v --tb=short --junitxml=test-results.xml

      - name: Upload Test Results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: auth-test-results
          path: auth_service/test-results.xml

  blockchain-tests:
    name: Blockchain Service Tests
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'
          cache-dependency-path: blockchain_service/requirements.txt

      - name: Install dependencies
        working-directory: blockchain_service
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install pytest pytest-asyncio httpx pytest-cov

      - name: Run Blockchain Tests
        working-directory: blockchain_service
        env:
          PYTHONPATH: ${{ github.workspace }}/blockchain_service:${{ github.workspace }}
          TESTING: "true"
        run: |
          pytest tests/ -v --tb=short --junitxml=test-results.xml

      - name: Upload Test Results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: blockchain-test-results
          path: blockchain_service/test-results.xml

  code-execution-tests:
    name: Code Execution Service Tests
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'
          cache-dependency-path: code_execution_service/requirements.txt

      - name: Install dependencies
        working-directory: code_execution_service
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install pytest pytest-asyncio httpx pytest-cov

      - name: Run Code Execution Tests
        working-directory: code_execution_service
        env:
          PYTHONPATH: ${{ github.workspace }}/code_execution_service:${{ github.workspace }}
          TESTING: "true"
        run: |
          pytest tests/ -v --tb=short --junitxml=test-results.xml

      - name: Upload Test Results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: code-execution-test-results
          path: code_execution_service/test-results.xml

  memory-tests:
    name: Memory Service Tests
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'
          cache-dependency-path: memory_service/requirements.txt

      - name: Install dependencies
        working-directory: memory_service
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install pytest pytest-asyncio httpx pytest-cov

      - name: Run Memory Tests
        working-directory: memory_service
        env:
          PYTHONPATH: ${{ github.workspace }}/memory_service:${{ github.workspace }}
          TESTING: "true"
        run: |
          pytest tests/ -v --tb=short --junitxml=test-results.xml

      - name: Upload Test Results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: memory-test-results
          path: memory_service/test-results.xml

  coverage-report:
    name: Combined Coverage Report
    runs-on: ubuntu-latest
    needs: [gateway-tests, auth-tests, blockchain-tests, code-execution-tests, memory-tests]
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install pytest pytest-cov coverage
          pip install -r gateway/requirements.txt
          pip install -r auth_service/requirements.txt
          pip install -r blockchain_service/requirements.txt

      - name: Run All Tests with Coverage
        env:
          PYTHONPATH: ${{ github.workspace }}
          TESTING: "true"
          JWT_SECRET_KEY: "test-jwt-secret-for-ci"
        run: |
          coverage run -m pytest gateway/tests auth_service/tests blockchain_service/tests -v --tb=short
          coverage report --show-missing
          coverage html

      - name: Upload Coverage Report
        uses: actions/upload-artifact@v4
        with:
          name: coverage-report
          path: htmlcov/

  test-summary:
    name: Test Summary
    runs-on: ubuntu-latest
    needs: [gateway-tests, auth-tests, blockchain-tests, code-execution-tests, memory-tests]
    if: always()
    steps:
      - name: Download all test results
        uses: actions/download-artifact@v4
        with:
          pattern: '*-test-results'
          merge-multiple: true

      - name: Test Summary
        run: |
          echo "## Backend Test Results" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "| Service | Status |" >> $GITHUB_STEP_SUMMARY
          echo "|---------|--------|" >> $GITHUB_STEP_SUMMARY
          echo "| Gateway | ${{ needs.gateway-tests.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Auth | ${{ needs.auth-tests.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Blockchain | ${{ needs.blockchain-tests.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Code Execution | ${{ needs.code-execution-tests.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Memory | ${{ needs.memory-tests.result }} |" >> $GITHUB_STEP_SUMMARY
