From: Deploy Bot <deploy@dev-swat.com>
Date: Sun, 22 Feb 2026 13:32:45 +0000
Subject: [PATCH] fix: Add owner dashboard RARA status endpoint and nginx
 routing

- Added /owner/dashboard/rara/status endpoint to gateway
- Added endpoint to auth middleware public paths
- Added RARA_SERVICE_URL environment variable to green gateway
- Added nginx location block for /owner/ paths
- Endpoint returns RARA node status without authentication
---
 docker-compose.green.complete.yml |  1 +
 gateway/app/auth_middleware.py    |  1 +
 gateway/app/main.py               | 34 +++++++++++++++++++++++++++++++
 3 files changed, 36 insertions(+)

diff --git a/docker-compose.green.complete.yml b/docker-compose.green.complete.yml
index 5ee1bd1..ecc253c 100644
--- a/docker-compose.green.complete.yml
+++ b/docker-compose.green.complete.yml
@@ -369,6 +369,7 @@ services:
       REDIS_URL: redis://shared_redis:6379/0
       USER_SERVICE_URL: http://green_user_service:8000
       DEPLOYMENT_COLOR: green
+      RARA_SERVICE_URL: http://green_rara_service:8093
     networks:
     - green-network
     - shared-network
diff --git a/gateway/app/auth_middleware.py b/gateway/app/auth_middleware.py
index 81bf9ca..d3464f8 100644
--- a/gateway/app/auth_middleware.py
+++ b/gateway/app/auth_middleware.py
@@ -67,6 +67,7 @@ class AuthMiddleware(BaseHTTPMiddleware):
             "/api/v1/api/auth/login",
             "/api/v1/api/auth/signup",
             "/api/v1/api/auth/providers",
+            "/owner/dashboard/rara/status",
         }
         public_prefixes = (
             "/docs", "/openapi", "/redoc", "/api/auth", "/api/v1/auth", "/auth", "/oauth",
diff --git a/gateway/app/main.py b/gateway/app/main.py
index 82b6d0b..af7cf12 100644
--- a/gateway/app/main.py
+++ b/gateway/app/main.py
@@ -799,3 +799,37 @@ async def public_proxy(request: Request, path: str):
 if __name__ == "__main__":
     import uvicorn
     uvicorn.run(app, host="0.0.0.0", port=8000)
+
+# ============================================
+# OWNER DASHBOARD RARA STATUS
+# ============================================
+@app.get("/owner/dashboard/rara/status")
+@edge_capture_decorator("gateway", "owner_dashboard_rara_status")
+async def owner_dashboard_rara_status(request: Request):
+    """Owner dashboard RARA status endpoint - public access."""
+    import httpx
+    rara_url = os.getenv('RARA_SERVICE_URL', 'http://rara_service:8093')
+    try:
+        async with httpx.AsyncClient() as client:
+            health_resp = await client.get(f"{rara_url}/health", timeout=10.0)
+            status_resp = await client.get(f"{rara_url}/status", timeout=10.0)
+            health_data = health_resp.json()
+            status_data = status_resp.json()
+            
+            return {
+                'running': health_data.get('status') == 'ok',
+                'online': health_data.get('status') == 'ok',
+                'status': health_data.get('status', 'unknown'),
+                'service': health_data.get('service', 'rara'),
+                'verified_agents': status_data.get('agents_registered', 0),
+                'state': status_data.get('state', 'unknown'),
+                'uptime_seconds': status_data.get('uptime_seconds', 0)
+            }
+    except Exception as e:
+        return {
+            'running': False,
+            'online': False,
+            'status': 'offline',
+            'error': str(e),
+            'verified_agents': 0
+        }
