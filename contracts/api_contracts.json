{
  "version": "1.0.0",
  "description": "Frontend-Backend API Contract Definitions",
  "last_validated": "2025-12-21",
  "contracts": [
    {
      "endpoint": "/auth/login",
      "method": "POST",
      "service": "auth_service",
      "request": {
        "content_type": "application/json",
        "required_fields": ["email", "password"],
        "optional_fields": ["org_id"],
        "schema": {
          "email": "string",
          "password": "string",
          "org_id": "string|null"
        }
      },
      "response": {
        "success_code": 200,
        "required_fields": ["access_token", "org_id", "role"],
        "optional_fields": ["user", "token_type"],
        "schema": {
          "access_token": "string",
          "token_type": "string",
          "org_id": "string",
          "role": "string",
          "user": "object|null"
        }
      },
      "error_modes": [
        {"code": 401, "detail": "Invalid email or password"},
        {"code": 429, "detail": "Too many login attempts"},
        {"code": 500, "detail": "Internal server error"}
      ]
    },
    {
      "endpoint": "/auth/register",
      "method": "POST",
      "service": "auth_service",
      "request": {
        "content_type": "application/json",
        "required_fields": ["email", "password", "username", "full_name"],
        "optional_fields": [],
        "schema": {
          "email": "string",
          "password": "string",
          "username": "string",
          "full_name": "string"
        }
      },
      "response": {
        "success_code": 200,
        "required_fields": ["access_token", "org_id", "role", "user"],
        "schema": {
          "access_token": "string",
          "token_type": "string",
          "org_id": "string",
          "role": "string",
          "user": {
            "id": "string",
            "email": "string",
            "username": "string",
            "full_name": "string"
          }
        }
      },
      "error_modes": [
        {"code": 400, "detail": "Email already registered"},
        {"code": 422, "detail": "Validation error"}
      ]
    },
    {
      "endpoint": "/resonant-chat/message",
      "method": "POST",
      "service": "chat_service",
      "request": {
        "content_type": "application/json",
        "required_fields": ["message"],
        "optional_fields": ["chatId", "context", "preferred_provider", "use_rag", "execute_mode"],
        "schema": {
          "message": "string",
          "chatId": "string|null",
          "context": "object|null",
          "preferred_provider": "string|null",
          "use_rag": "boolean|null",
          "execute_mode": "boolean|null"
        }
      },
      "response": {
        "success_code": 200,
        "required_fields": ["message"],
        "optional_fields": ["anchors", "hash", "resonanceScore", "aiProvider", "memoryUpdated", "chatId"],
        "schema": {
          "message": {
            "id": "string",
            "role": "string",
            "content": "string",
            "timestamp": "string|null"
          },
          "anchors": "array",
          "hash": "string",
          "resonanceScore": "number",
          "aiProvider": "string",
          "memoryUpdated": "boolean",
          "chatId": "string|null"
        }
      },
      "error_modes": [
        {"code": 401, "detail": "Unauthorized"},
        {"code": 500, "detail": "Internal server error"}
      ]
    },
    {
      "endpoint": "/agents",
      "method": "GET",
      "service": "agent_engine_service",
      "request": {
        "content_type": null,
        "required_fields": [],
        "optional_fields": []
      },
      "response": {
        "success_code": 200,
        "type": "array",
        "item_schema": {
          "id": "string",
          "name": "string",
          "status": "string",
          "capabilities": "array"
        }
      },
      "error_modes": [
        {"code": 401, "detail": "Unauthorized"},
        {"code": 500, "detail": "Internal server error"}
      ]
    },
    {
      "endpoint": "/agent-teams",
      "method": "GET",
      "service": "agent_engine_service",
      "request": {
        "content_type": null,
        "required_fields": [],
        "optional_fields": []
      },
      "response": {
        "success_code": 200,
        "type": "array",
        "item_schema": {
          "id": "string",
          "name": "string",
          "members": "array"
        }
      },
      "error_modes": [
        {"code": 401, "detail": "Unauthorized"}
      ]
    },
    {
      "endpoint": "/rara/status",
      "method": "GET",
      "service": "rara_service",
      "request": {
        "content_type": null,
        "required_fields": [],
        "optional_fields": []
      },
      "response": {
        "success_code": 200,
        "required_fields": ["state"],
        "optional_fields": ["active_mutation", "last_snapshot", "agents_registered", "mutations_pending"],
        "schema": {
          "state": "string",
          "active_mutation": "string|null",
          "last_snapshot": "string|null",
          "agents_registered": "number|null",
          "mutations_pending": "number|null"
        }
      },
      "error_modes": [
        {"code": 503, "detail": "Service unavailable"}
      ]
    },
    {
      "endpoint": "/hashsphere/state",
      "method": "GET",
      "service": "hash_sphere_service",
      "request": {
        "content_type": null,
        "required_fields": [],
        "optional_fields": []
      },
      "response": {
        "success_code": 200,
        "required_fields": ["nodes"],
        "schema": {
          "nodes": "array"
        }
      },
      "error_modes": [
        {"code": 503, "detail": "Service unavailable"}
      ]
    },
    {
      "endpoint": "/user/profile",
      "method": "GET",
      "service": "user_service",
      "request": {
        "content_type": null,
        "required_fields": [],
        "headers_required": ["Authorization"]
      },
      "response": {
        "success_code": 200,
        "required_fields": ["id", "email"],
        "optional_fields": ["full_name", "role", "org_id", "created_at"]
      },
      "error_modes": [
        {"code": 401, "detail": "Unauthorized"},
        {"code": 404, "detail": "User not found"}
      ]
    },
    {
      "endpoint": "/orgs",
      "method": "GET",
      "service": "gateway",
      "request": {
        "content_type": null,
        "required_fields": [],
        "headers_required": ["Authorization"]
      },
      "response": {
        "success_code": 200,
        "type": "array|object"
      },
      "error_modes": [
        {"code": 401, "detail": "Unauthorized"}
      ]
    },
    {
      "endpoint": "/policies",
      "method": "GET",
      "service": "gateway",
      "request": {
        "content_type": null,
        "required_fields": []
      },
      "response": {
        "success_code": 200,
        "type": "array"
      },
      "error_modes": [
        {"code": 401, "detail": "Unauthorized"}
      ]
    }
  ]
}
