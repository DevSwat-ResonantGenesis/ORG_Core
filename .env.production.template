# RESONANT GENESIS - PRODUCTION ENVIRONMENT TEMPLATE
# Copy to .env.production and fill in values
# NEVER commit actual secrets to git!

# ============== ENVIRONMENT ==============
NODE_ENV=production
GATEWAY_ENV=production

# ============== SECRET MANAGEMENT ==============
# Options: env, aws, vault
SECRET_BACKEND=env

# For AWS Secrets Manager
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=  # Or use IAM role
# AWS_SECRET_ACCESS_KEY=

# For HashiCorp Vault
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=

# ============== DATABASE PASSWORDS ==============
# Generate secure passwords: openssl rand -base64 32
AUTH_DB_PASS=CHANGE_ME_auth_secure_password_here
CHAT_DB_PASS=CHANGE_ME_chat_secure_password_here
MEMORY_DB_PASS=CHANGE_ME_memory_secure_password_here
AGENT_DB_PASS=CHANGE_ME_agent_secure_password_here
BILLING_DB_PASS=CHANGE_ME_billing_secure_password_here
BLOCKCHAIN_DB_PASS=CHANGE_ME_blockchain_secure_password_here
NOTIFICATION_DB_PASS=CHANGE_ME_notification_secure_password_here

# Rabbit (private Reddit-like platform)
RABBIT_DATABASE_URL=postgresql+asyncpg://rabbit:rabbit@rabbit_db:5432/rabbit

# ============== REDIS ==============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============== JWT & SECURITY ==============
# Generate: openssl rand -base64 64
JWT_SECRET_KEY=CHANGE_ME_generate_secure_jwt_secret_key
SEED_ENCRYPTION_KEY=CHANGE_ME_generate_secure_seed_encryption_key

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============== LLM API KEYS ==============
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
GROQ_API_KEY=gsk_...

# ============== STRIPE (Billing) ==============
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ============== EMAIL (Choose one) ==============
# SendGrid
SENDGRID_API_KEY=SG....

# OR AWS SES (uses AWS credentials above)

# OR SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=info@dev-swat.com
FROM_NAME=DevSwat

# ============== SENTRY (Error Tracking) ==============
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0

# ============== MONITORING ==============
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_flower_password

# ============== DOMAINS ==============
FRONTEND_URL=https://dev-swat.com
API_URL=https://api.dev-swat.com
CORS_ORIGINS=https://dev-swat.com,https://www.dev-swat.com,https://api.dev-swat.com

# ============== SSL/TLS ==============
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# ============== FEATURE FLAGS ==============
AUTO_START_AUTONOMY=true
ENABLE_BLOCKCHAIN=true
ENABLE_BILLING=true

# ============== RATE LIMITING ==============
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============== CODE VISUALIZER ==============
STORAGE_SERVICE_URL=http://storage_service:8000/api/storage
CODE_UPLOAD_BUCKET=code-uploads
CODE_UPLOAD_MAX_MB=100
CODE_UPLOAD_MAX_FILES=10000
CODE_UPLOAD_MAX_UNPACKED_MB=500
CODE_UPLOAD_SCAN_TIMEOUT_SEC=120

# ============== LOGGING ==============
LOG_LEVEL=INFO
LOG_FORMAT=json
