#!/bin/bash
# CASCADE Control Plane - Pre-commit Hook
# ENFORCEMENT POINT: Blocks commits without impact analysis

set -e

CASCADE_URL="${CASCADE_URL:-http://localhost:8095}"
BYPASS_CASCADE="${BYPASS_CASCADE:-false}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}═══════════════════════════════════════════════════════════════${NC}"
echo -e "${YELLOW}                    CASCADE CONTROL PLANE                        ${NC}"
echo -e "${YELLOW}═══════════════════════════════════════════════════════════════${NC}"

# Check if CASCADE is running
if ! curl -s "${CASCADE_URL}/health" > /dev/null 2>&1; then
    echo -e "${RED}ERROR: CASCADE Control Plane not running at ${CASCADE_URL}${NC}"
    echo -e "${RED}Start CASCADE before committing: cd cascade_control_plane && python3 run.py${NC}"
    exit 1
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(py|ts|tsx|js|jsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}No code files staged. Proceeding.${NC}"
    exit 0
fi

echo -e "Checking impact for ${YELLOW}$(echo "$STAGED_FILES" | wc -l | tr -d ' ')${NC} files..."

BLOCKED=false
CRITICAL_FILES=""
HIGH_RISK_FILES=""

for FILE in $STAGED_FILES; do
    # Skip test files
    if [[ "$FILE" == *"test"* ]] || [[ "$FILE" == *"spec"* ]]; then
        continue
    fi
    
    # Call CASCADE impact API
    RESPONSE=$(curl -s -X POST "${CASCADE_URL}/api/impact" \
        -H "Content-Type: application/json" \
        -d "{\"file_path\": \"${FILE}\", \"change_type\": \"modify\"}" 2>/dev/null || echo '{"error": true}')
    
    # Check for errors
    if echo "$RESPONSE" | grep -q '"error"'; then
        echo -e "${YELLOW}⚠ Could not analyze: ${FILE}${NC}"
        continue
    fi
    
    # Extract risk level
    RISK_LEVEL=$(echo "$RESPONSE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('impact',{}).get('risk_level','unknown'))" 2>/dev/null || echo "unknown")
    
    # Extract blockers
    BLOCKERS=$(echo "$RESPONSE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('impact',{}).get('blockers',[])))" 2>/dev/null || echo "0")
    
    case "$RISK_LEVEL" in
        "critical")
            echo -e "${RED}🔴 CRITICAL: ${FILE}${NC}"
            CRITICAL_FILES="${CRITICAL_FILES}\n  - ${FILE}"
            BLOCKED=true
            ;;
        "high")
            echo -e "${YELLOW}🟠 HIGH: ${FILE}${NC}"
            HIGH_RISK_FILES="${HIGH_RISK_FILES}\n  - ${FILE}"
            if [ "$BLOCKERS" -gt 0 ]; then
                BLOCKED=true
            fi
            ;;
        "medium")
            echo -e "${YELLOW}🟡 MEDIUM: ${FILE}${NC}"
            ;;
        "low")
            echo -e "${GREEN}🟢 LOW: ${FILE}${NC}"
            ;;
        *)
            echo -e "${YELLOW}⚠ UNCLASSIFIED: ${FILE}${NC}"
            # Default deny for unclassified
            BLOCKED=true
            ;;
    esac
done

echo ""

if [ "$BLOCKED" = true ]; then
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}                      COMMIT BLOCKED                            ${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    
    if [ -n "$CRITICAL_FILES" ]; then
        echo -e "${RED}CRITICAL ZONE FILES (requires explicit approval):${NC}"
        echo -e "$CRITICAL_FILES"
    fi
    
    if [ -n "$HIGH_RISK_FILES" ]; then
        echo -e "${YELLOW}HIGH RISK FILES:${NC}"
        echo -e "$HIGH_RISK_FILES"
    fi
    
    echo ""
    echo -e "${YELLOW}To proceed:${NC}"
    echo -e "  1. Get approval for critical zone changes"
    echo -e "  2. Run: BYPASS_CASCADE=true git commit (emergency only)"
    echo -e "  3. Or fix the issues and try again"
    echo ""
    
    # Check for bypass (emergency only)
    if [ "$BYPASS_CASCADE" = "true" ]; then
        echo -e "${RED}⚠️  BYPASS_CASCADE=true - Proceeding without approval${NC}"
        echo -e "${RED}⚠️  This will be logged in audit trail${NC}"
        
        # Log bypass to CASCADE
        curl -s -X POST "${CASCADE_URL}/api/audit" \
            -H "Content-Type: application/json" \
            -d "{\"action\": \"bypass\", \"files\": \"${STAGED_FILES}\", \"actor\": \"$(git config user.email)\"}" > /dev/null 2>&1 || true
        
        exit 0
    fi
    
    exit 1
fi

echo -e "${GREEN}═══════════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}                    IMPACT CHECK PASSED                         ${NC}"
echo -e "${GREEN}═══════════════════════════════════════════════════════════════${NC}"
exit 0
